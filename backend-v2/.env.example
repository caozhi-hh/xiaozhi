# === AI 模型配置 ===
# 格式：MODEL_名称=base_url|api_key|model_name
MODEL_GLM_4_FLASH=open.bigmodel.cn/api/paas/v4|your_key|glm-4-flash
MODEL_QWEN_MAX=dashscope.aliyuncs.com/compatible-mode/v1|your_key|qwen-max

# === 图片生成 ===
SILICONFLOW_API_KEY=your_siliconflow_key

# === 企业微信 - 自建应用 ===
WECOM_CORP_ID=ww1234567890
WECOM_AGENT_ID=1000002
WECOM_SECRET=your_agent_secret
WECOM_TOKEN=your_callback_token
WECOM_ENCODING_AES_KEY=your_43_char_aes_key

# === 企业微信 - 群机器人 Webhook ===
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_webhook_key
